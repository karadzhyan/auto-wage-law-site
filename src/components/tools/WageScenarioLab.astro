<div class="scenario-lab" data-wage-scenario-lab>
  <form class="scenario-inputs" data-scenario-form novalidate>
    <div class="panel-head">
      <div><p class="data-label">Input register · scenario, not forecast</p><h2>Define the entered layers.</h2></div>
      <span>Ephemeral in this browser</span>
    </div>

    <fieldset>
      <legend><span>01</span> Population and period</legend>
      <div class="field-grid field-grid--two">
        <label><span>Employees in entered group</span><input name="employees" type="number" min="0" max="100000" step="1" value="12" required /></label>
        <label><span>Entered workweeks</span><input name="workweeks" type="number" min="0" max="520" step="1" value="156" required /></label>
      </div>
      <p class="field-limit">The instrument does not select a group or limitations period. These are user-entered arithmetic bounds.</p>
    </fieldset>

    <fieldset>
      <legend><span>02</span> Weekly-hour sensitivities</legend>
      <div class="sensitivity-inputs">
        <label><span><b>Low</b> entered gap</span><div><input name="gapLow" type="number" min="0" max="168" step="0.01" value="0.5" required /><em>hr / wk</em></div></label>
        <label><span><b>Base</b> entered gap</span><div><input name="gapBase" type="number" min="0" max="168" step="0.01" value="2" required /><em>hr / wk</em></div></label>
        <label><span><b>High</b> entered gap</span><div><input name="gapHigh" type="number" min="0" max="168" step="0.01" value="4" required /><em>hr / wk</em></div></label>
      </div>
      <p class="field-limit">Low ≤ Base ≤ High. An entered gap is not a determination that time was worked, compensable, or unpaid.</p>
    </fieldset>

    <fieldset>
      <legend><span>03</span> Straight-time layer</legend>
      <label class="row-field"><span>Entered hourly rate</span><div class="money-field"><b>$</b><input name="straightTimeRate" type="number" min="0" max="10000" step="0.01" value="28" required /><em>/ hr</em></div></label>
    </fieldset>

    <fieldset>
      <legend><span>04</span> Optional overtime increment</legend>
      <label class="toggle"><input name="includeOvertime" type="checkbox" checked /><span>Include an entered overtime-increment layer</span></label>
      <div class="field-grid field-grid--two" data-overtime-fields>
        <label><span>Share of entered gap in overtime</span><div class="unit-field"><input name="overtimeShare" type="number" min="0" max="100" step="0.1" value="25" required /><em>%</em></div></label>
        <label><span>Additional multiplier</span><div class="unit-field"><input name="overtimeIncrement" type="number" min="0" max="10" step="0.01" value="0.5" required /><em>× rate</em></div></label>
      </div>
    </fieldset>

    <fieldset>
      <legend><span>05</span> Optional premium-hour layer</legend>
      <label class="toggle"><input name="includePremiumHours" type="checkbox" /><span>Include separately entered premium hours</span></label>
      <div class="field-grid field-grid--two" data-premium-fields>
        <label><span>Premium hours per workweek</span><div class="unit-field"><input name="premiumHoursPerWeek" type="number" min="0" max="168" step="0.01" value="0" required /><em>hr</em></div></label>
        <label><span>Entered premium rate</span><div class="money-field"><b>$</b><input name="premiumRate" type="number" min="0" max="10000" step="0.01" value="28" required /><em>/ hr</em></div></label>
      </div>
    </fieldset>

    <div class="form-error" data-scenario-error role="alert" tabindex="-1" hidden></div>
    <div class="tool-actions">
      <button class="button" type="submit">Recalculate layers <span aria-hidden="true">→</span></button>
      <button class="reset-button" type="reset">Reset synthetic example</button>
    </div>
    <p class="privacy-note">Inputs remain in memory on this device and disappear when the page is reloaded or closed.</p>
  </form>

  <section class="scenario-output" data-scenario-output tabindex="-1" aria-live="polite">
    <div class="panel-head">
      <div><p class="data-label">Sensitivity ledger</p><h2>Three entered cases. Three visible layers.</h2></div>
      <span data-scenario-status>Illustrative defaults</span>
    </div>

    <div class="table-wrap" tabindex="0" role="region" aria-label="Scenario calculations">
      <table>
        <thead><tr><th scope="col">Case</th><th scope="col">Gap / week</th><th scope="col">Straight time</th><th scope="col">OT increment</th><th scope="col">Premium hours</th><th scope="col">Entered total</th></tr></thead>
        <tbody>
          <tr data-scenario-row="low"><th scope="row"><span>01</span>Low</th><td data-cell="gap">0.5 hr</td><td data-cell="straight">$26,208</td><td data-cell="overtime">$3,276</td><td data-cell="premium">$0</td><td data-cell="total">$29,484</td></tr>
          <tr data-scenario-row="base"><th scope="row"><span>02</span>Base</th><td data-cell="gap">2 hr</td><td data-cell="straight">$104,832</td><td data-cell="overtime">$13,104</td><td data-cell="premium">$0</td><td data-cell="total">$117,936</td></tr>
          <tr data-scenario-row="high"><th scope="row"><span>03</span>High</th><td data-cell="gap">4 hr</td><td data-cell="straight">$209,664</td><td data-cell="overtime">$26,208</td><td data-cell="premium">$0</td><td data-cell="total">$235,872</td></tr>
        </tbody>
      </table>
    </div>

    <section class="formula-register" aria-labelledby="formula-title">
      <div><p class="data-label">Formula register</p><h3 id="formula-title">Every total remains decomposable.</h3></div>
      <dl>
        <div><dt>Straight time</dt><dd data-formula="straight">employees × workweeks × entered weekly gap × entered rate</dd></div>
        <div><dt>OT increment</dt><dd data-formula="overtime">employees × workweeks × entered weekly gap × entered overtime share × entered rate × entered increment</dd></div>
        <div><dt>Premium hours</dt><dd data-formula="premium">employees × workweeks × entered premium hours per workweek × entered premium rate</dd></div>
      </dl>
    </section>

    <section class="boundary-register" aria-labelledby="boundary-title">
      <div><p class="data-label">Interpretation boundary</p><h3 id="boundary-title">Arithmetic on entered assumptions</h3><p data-interpretation-boundary>This is arithmetic on entered assumptions—not a conclusion about covered hours, applicable rates, group composition, time period, responsibility, or recoverable amounts.</p></div>
      <div><p class="data-label">Excluded from every total</p><ul data-scenario-exclusions></ul></div>
    </section>

    <button class="print-button no-print" type="button" data-print-scenarios>Print scenario ledger</button>
  </section>
</div>

<script>
  import { initializeWageScenarioLab } from '../../scripts/wage-scenario-lab.ts';
  initializeWageScenarioLab();
</script>

