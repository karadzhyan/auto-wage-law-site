---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LibraryIndex from '../../components/LibraryIndex.astro';
---

<BaseLayout title="Issue library" description="Eight dealership wage-and-hour collision points with bounded explanations and primary sources.">
  <main id="main-content">
    <header class="index-hero shell"><p class="eyebrow">Eight collision points</p><h1>Trace the issue.</h1><p class="lede">Move from recorded time and incentive pay to the rule that controls the next question.</p></header>
    <section class="shell section section--ruled"><LibraryIndex /></section>
  </main>
</BaseLayout>

<style>.index-hero { padding-block: var(--space-9); } .index-hero h1 { margin-bottom: 1.5rem; }</style>
