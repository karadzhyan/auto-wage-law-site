---
import { developments } from '../data/library';
---

<div class="development-list">
  {developments.map((item) => (
    <article>
      <time datetime={item.date}>{item.date}</time>
      <div><p>{item.label}</p><h3>{item.title}</h3><span>{item.description}</span></div>
    </article>
  ))}
</div>

<style>
  .development-list { border-top: 3px solid var(--color-ink); }
  article { display: grid; grid-template-columns: 9rem minmax(0, 1fr); gap: var(--space-6); border-bottom: var(--rule); padding-block: 1.5rem; }
  time, article p { color: var(--color-cobalt-dark); font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  article p { margin-bottom: 0.45rem; }
  h3 { margin-bottom: 0.45rem; font-size: clamp(1.3rem, 2.5vw, 2rem); }
  article span { color: var(--color-muted); }
  @media (max-width: 38rem) { article { grid-template-columns: 1fr; gap: 0.6rem; } }
</style>
