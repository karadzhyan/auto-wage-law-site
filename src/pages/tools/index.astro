---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnalysisSequence from '../../components/AnalysisSequence.astro';

const tools = [
  {
    number: '01',
    stage: 'Facts · Classify · Test · Verify',
    title: 'Pay System Analyzer',
    description: 'Enter the role, establishment, pay methods, time reconciliation, claimed route, and available proof. Receive independent predicates and a matched record pull.',
    output: 'Questions, predicates, and records—not a verdict.',
    href: '/tools/pay-system-analyzer/',
  },
  {
    number: '02',
    stage: 'Measure',
    title: 'Wage Scenario Lab',
    description: 'Compare low, base, and high entered weekly-hour sensitivities while keeping straight time, overtime increment, and premium hours in separate layers.',
    output: 'Decomposed arithmetic—not a forecast.',
    href: '/tools/wage-scenario-lab/',
  },
  {
    number: '03',
    stage: 'Classify · Verify',
    title: 'Commission Ledger',
    description: 'Trace synthetic or entered transaction credits and debits through classification, earning-event, timing, and later-debit evidence questions.',
    output: 'Transaction reconciliation—not a pay conclusion.',
    href: '/tools/commission-ledger/',
  },
];
---

<BaseLayout title="Analytical instruments" description="Three browser-local instruments for mapping a pay system, decomposing wage assumptions, and reconciling commission transactions.">
  <main id="main-content">
    <header class="tools-hero shell">
      <p class="eyebrow">Educational instruments · browser local · nothing retained</p>
      <div class="hero-grid"><h1>Interrogate the inputs.<br /><span>Preserve the boundary.</span></h1><p class="lede">Each instrument performs one bounded analytical job and exposes the assumptions, formulas, records, and unresolved predicates behind its output.</p></div>
      <AnalysisSequence variant="compact" />
    </header>
    <section class="shell section tool-list" aria-label="Available instruments">
      {tools.map((tool) => (
        <a href={tool.href}>
          <span class="tool-number">{tool.number}</span>
          <div class="tool-title"><p>{tool.stage}</p><h2>{tool.title}</h2></div>
          <p class="tool-description">{tool.description}</p>
          <div class="tool-output"><span>Output boundary</span><strong>{tool.output}</strong></div>
          <b aria-hidden="true">→</b>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .tools-hero { padding-block: var(--space-9) var(--space-7); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 2fr) minmax(18rem, 0.8fr); gap: var(--space-8); align-items: end; margin-bottom: var(--space-7); }
  .hero-grid h1,
  .hero-grid p { margin-bottom: 0; }
  .hero-grid h1 span { color: var(--color-cobalt); }
  .tool-list { border-top: 4px solid var(--color-ink); }
  .tool-list a { display: grid; grid-template-columns: 3rem minmax(12rem, 1fr) minmax(16rem, 1.4fr) minmax(12rem, 0.8fr) 1.5rem; gap: var(--space-5); align-items: start; border-bottom: var(--rule); padding-block: 1.8rem; color: var(--color-text); text-decoration: none; }
  .tool-list a:hover { background: var(--color-paper-blue); }
  .tool-number,
  .tool-title p,
  .tool-output span { color: var(--color-cobalt-dark); font-family: var(--font-mono); font-size: 0.64rem; font-weight: 600; text-transform: uppercase; }
  .tool-title p,
  .tool-title h2,
  .tool-description { margin-bottom: 0; }
  .tool-title h2 { margin-top: 0.4rem; font-size: 1.8rem; }
  .tool-description { font-size: 0.92rem; }
  .tool-output { display: grid; gap: 0.4rem; border-left: 3px solid var(--color-signal); padding-left: 0.8rem; }
  .tool-output strong { color: var(--color-ink); font-size: 0.83rem; line-height: 1.4; }
  .tool-list a > b { color: var(--color-cobalt); font-size: 1.4rem; }
  @media (max-width: 60rem) { .tool-list a { grid-template-columns: 2.5rem 1fr 1fr 1.5rem; } .tool-description { grid-column: 2 / 4; } .tool-output { grid-column: 2 / 4; } .tool-list a > b { grid-column: 4; grid-row: 1; } }
  @media (max-width: 46rem) { .hero-grid { grid-template-columns: 1fr; gap: var(--space-4); } .tool-list a { grid-template-columns: 2rem 1fr 1rem; } .tool-title, .tool-description, .tool-output { grid-column: 2; } .tool-list a > b { grid-column: 3; } }
</style>
