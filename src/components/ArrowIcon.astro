---
interface Props {
  direction?: 'right' | 'down';
}
const { direction = 'right' } = Astro.props;
---

<svg
  width="18"
  height="18"
  viewBox="0 0 18 18"
  fill="none"
  aria-hidden="true"
  class:list={[direction === 'down' && 'arrow--down']}
>
  <path d="M3 9h11M10 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
</svg>

<style>
  .arrow--down {
    transform: rotate(90deg);
  }
</style>
