---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import type { AuthorityId } from '../../data/authorities';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  return entries.map((entry) => {
    const [section, slug] = entry.id.split('/');
    return { params: { section, slug }, props: { entry } };
  });
}

interface Props { entry: CollectionEntry<'articles'>; }
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  section={entry.data.section}
  question={entry.data.question}
  analysisStep={entry.data.analysisStep}
  jurisdictions={entry.data.jurisdictions}
  sourceChecked={entry.data.sourceChecked}
  checkScope={entry.data.checkScope}
  nextCheck={entry.data.nextCheck}
  authorityIds={entry.data.authorityIds as AuthorityId[]}
  evidenceDomains={entry.data.evidenceDomains}
  related={entry.data.related}
  headings={headings}
  feature={entry.data.feature}
>
  <Content />
</ArticleLayout>
