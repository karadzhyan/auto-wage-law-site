---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnalysisSequence from '../components/AnalysisSequence.astro';
import SourceCheck from '../components/SourceCheck.astro';

const controls = [
  { id: 'C01', control: 'Work and time capture', cadence: 'Daily / each shift', owner: 'Operations + payroll', evidence: 'Raw punches, edit trail, schedule, activity exceptions', trigger: 'Scheduled, system, or production activity outside recorded time' },
  { id: 'C02', control: 'Pay-plan versioning', cadence: 'Before effective date', owner: 'HR + compensation', evidence: 'Signed version, receipt, formula, code map, effective dates', trigger: 'Practice, code, or formula differs from the operative writing' },
  { id: 'C03', control: 'Coverage-route file', cadence: 'At classification and role change', owner: 'HR + counsel', evidence: 'Entity, establishment, actual duties, route predicates', trigger: 'Title or federal route is doing work that the facts do not support' },
  { id: 'C04', control: 'Period reconciliation', cadence: 'Before payroll closes', owner: 'Payroll + department', evidence: 'Time × output/deals × pay register × statement', trigger: 'A unit, hour, premium, rate, or transaction does not trace across systems' },
  { id: 'C05', control: 'Commission debit trace', cadence: 'Each later debit', owner: 'Sales accounting', evidence: 'Transaction, plan condition, event proof, both statement lines', trigger: 'Pooled loss, unexplained code, or missing transaction-level connection' },
  { id: 'C06', control: 'Correction and preservation', cadence: 'At identified variance', owner: 'Named control owner', evidence: 'Raw data hold, correction log, affected periods, decision record', trigger: 'A variance repeats, source data can change, or the predicate remains unresolved' },
];
---

<BaseLayout title="For dealers" description="A control-oriented path for dealership operators, controllers, payroll, HR, and counsel to map and test a pay system before drawing conclusions.">
  <main id="main-content">
    <header class="audience-hero shell">
      <p class="eyebrow">Dealer path · control architecture</p>
      <div class="hero-grid">
        <h1>Audit the pay system before a dispute defines it.</h1>
        <p class="lede">A defensible review identifies the work, classifies every pay component, aligns the measurement unit, tests each legal route separately, and preserves the record behind the decision.</p>
      </div>
      <AnalysisSequence />
      <SourceCheck sourceChecked="2026-07-18" nextCheck="2027-01-15" checkScope="Dealer control sequence, source boundaries, record architecture, and links to current analytical instruments." />
    </header>

    <section class="section shell" aria-labelledby="control-title">
      <div class="section-heading"><div><p class="eyebrow">Operational control matrix</p><h2 id="control-title">Give every inference an owner and a record.</h2></div><p>The control question is not merely whether payroll totals. It is whether the facts, rule selection, calculation, proof, and corrective action can be reconstructed for the same period.</p></div>
      <div class="control-table" tabindex="0" role="region" aria-label="Scrollable dealer control matrix">
        <table>
          <thead><tr><th scope="col">Control</th><th scope="col">Cadence</th><th scope="col">Owner</th><th scope="col">Minimum evidence</th><th scope="col">Escalation trigger</th></tr></thead>
          <tbody>{controls.map((item) => <tr><th scope="row"><span>{item.id}</span>{item.control}</th><td>{item.cadence}</td><td>{item.owner}</td><td>{item.evidence}</td><td>{item.trigger}</td></tr>)}</tbody>
        </table>
      </div>
    </section>

    <section class="section section--mist">
      <div class="shell decision-record">
        <div><p class="eyebrow">Minimum decision record</p><h2>A conclusion without its predicates is not an audit trail.</h2><p>For each pay system and period, retain the precise question, source version, fact set, calculation unit, corroborating and contradictory proof, unresolved issue, action owner, and re-check date.</p></div>
        <ol>
          <li><span>01</span><strong>Define the tested proposition.</strong><p>Example: whether a claimed federal overtime route has each establishment, duty, pay, and record predicate—not whether the employee is “exempt” in the abstract.</p></li>
          <li><span>02</span><strong>Attach the matched packet.</strong><p>Plan, raw time, system or output detail, pay register, statement, audit trail, and any correction must cover identified dates and entities.</p></li>
          <li><span>03</span><strong>Record the boundary.</strong><p>State which California, federal, local, classification, remedy, or factual question remains outside the determination.</p></li>
          <li><span>04</span><strong>Close the control loop.</strong><p>Name the system owner, correction, preservation step, affected population, due date, and source-check trigger.</p></li>
        </ol>
      </div>
    </section>

    <section class="section shell instrument-path">
      <div><p class="eyebrow">Browser-local instruments</p><h2>Move from architecture to a bounded working paper.</h2></div>
      <div class="instrument-links">
        <a href="/tools/pay-system-analyzer/"><span>01 · Facts / test / verify</span><strong>Analyze one pay system</strong><p>Surface independent predicates, reconciliation questions, and the next record pull.</p></a>
        <a href="/tools/wage-scenario-lab/"><span>02 · Measure</span><strong>Decompose entered wage layers</strong><p>Keep low, base, and high arithmetic separate from the decision about which inputs control.</p></a>
        <a href="/tools/commission-ledger/"><span>03 · Classify / verify</span><strong>Trace transaction credits and debits</strong><p>Test classification, earning-event, timing, and later-debit proof transaction by transaction.</p></a>
      </div>
      <a class="text-link" href="/records/">Open the complete evidence map</a>
    </section>
  </main>
</BaseLayout>

<style>
  .audience-hero { padding-block: var(--space-9) var(--space-7); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 2fr) minmax(18rem, 0.8fr); gap: var(--space-8); align-items: end; margin-bottom: var(--space-7); }
  .hero-grid h1,
  .hero-grid p { margin-bottom: 0; }
  .control-table { overflow-x: auto; }
  table { width: 100%; min-width: 68rem; border-collapse: collapse; table-layout: fixed; }
  th,
  td { border-right: var(--rule); border-bottom: var(--rule); padding: 0.85rem 0.7rem; text-align: left; vertical-align: top; }
  thead th { border-top: 4px solid var(--color-ink); background: var(--color-paper-blue); color: var(--color-muted); font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; }
  thead th:first-child,
  tbody th { border-left: var(--rule); }
  tbody th { color: var(--color-ink); font-family: var(--font-display); font-size: 1rem; }
  tbody th span { display: block; margin-bottom: 0.35rem; color: var(--color-cobalt); font-family: var(--font-mono); font-size: 0.62rem; }
  tbody td { font-size: 0.82rem; line-height: 1.4; }
  tbody td:last-child { box-shadow: inset 3px 0 0 var(--color-signal); }
  .decision-record { display: grid; grid-template-columns: minmax(16rem, 0.9fr) minmax(0, 1.6fr); gap: var(--space-8); }
  .decision-record ol { margin: 0; padding: 0; border-top: 4px solid var(--color-ink); list-style: none; }
  .decision-record li { display: grid; grid-template-columns: 2.5rem minmax(12rem, 0.8fr) minmax(0, 1.4fr); gap: var(--space-4); border-bottom: var(--rule); padding-block: 1rem; }
  .decision-record li span { color: var(--color-cobalt); font-family: var(--font-mono); font-size: 0.68rem; }
  .decision-record li strong { font-family: var(--font-display); }
  .decision-record li p { margin: 0; font-size: 0.86rem; }
  .instrument-path { display: grid; grid-template-columns: minmax(15rem, 0.8fr) minmax(0, 1.8fr); gap: var(--space-8); border-top: 4px solid var(--color-ink); }
  .instrument-links { border-top: var(--rule); }
  .instrument-links a { display: grid; grid-template-columns: 10rem 1fr 1.3fr; gap: var(--space-4); border-bottom: var(--rule); padding-block: 1rem; color: var(--color-text); text-decoration: none; }
  .instrument-links a:hover { background: var(--color-paper-blue); }
  .instrument-links span { color: var(--color-cobalt-dark); font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; }
  .instrument-links strong { color: var(--color-ink); font-family: var(--font-display); }
  .instrument-links p { margin: 0; font-size: 0.82rem; }
  .instrument-path > .text-link { grid-column: 2; }
  @media (max-width: 56rem) { .hero-grid, .decision-record, .instrument-path { grid-template-columns: 1fr; } .instrument-path > .text-link { grid-column: 1; } }
  @media (max-width: 40rem) { .decision-record li { grid-template-columns: 2rem 1fr; } .decision-record li p { grid-column: 2; } .instrument-links a { grid-template-columns: 1fr; } }
</style>
