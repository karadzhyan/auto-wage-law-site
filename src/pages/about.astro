---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnalysisSequence from '../components/AnalysisSequence.astro';
import SourceCheck from '../components/SourceCheck.astro';
import { site } from '../data/site';

const releaseGates = [
  { number: '01', object: 'Authority proposition', gate: 'Official primary source, pinpoint where useful, jurisdiction, status, and a statement of what the source does not decide.' },
  { number: '02', object: 'Threshold or constant', gate: 'Effective date, formula, official source, unit, scope limit, and a scheduled re-check.' },
  { number: '03', object: 'Analytical guide', gate: 'Question, rule architecture, decision sequence, evidence map, worked example, strategic implications, limits, and primary authority.' },
  { number: '04', object: 'Instrument output', gate: 'Tested pure model, visible inputs and formulas, independent findings, exclusions, local-only operation, reset, print, and no outcome score.' },
  { number: '05', object: 'Product release', gate: 'Type check, tests, static build, internal-link audit, responsive interaction review, source check, and dated change record.' },
];
---

<BaseLayout title="About the method" description="How Auto Wage Law structures dealership wage-and-hour analysis, bounds source propositions, tests instruments, and records source checks.">
  <main id="main-content">
    <header class="page-hero shell">
      <p class="eyebrow">Product and editorial method · {site.reviewed}</p>
      <div class="hero-grid"><h1>Built to preserve the chain of reasoning.</h1><p class="lede">Auto Wage Law is an independent educational system for analyzing retail-automotive compensation. It begins with the work and pay mechanics, then keeps classification, measurement, legal testing, proof, and action in distinct lanes.</p></div>
      <AnalysisSequence />
      <SourceCheck sourceChecked="2026-07-18" nextCheck="2027-01-15" checkScope="Method statement, release gates, authority-register structure, threshold provenance, product boundaries, and instrument privacy claims." />
    </header>

    <section class="section shell purpose-grid">
      <div><p class="eyebrow">Purpose</p><h2>A better first-pass record, not a substitute for judgment.</h2></div>
      <div class="purpose-copy">
        <p>Dealership pay has a specialized operational vocabulary—flag hours, repair orders, front and back gross, packs, minis, draws, spiffs, CSI components, funding events, reversals, and chargebacks. Those labels are useful facts. They are not self-executing legal classifications.</p>
        <p>The site translates that operational system into auditable questions: what work occurred, what each payment compensates, which period and unit control the math, which California and federal routes must be tested, what the matched records establish, and what remains unresolved.</p>
        <p>It is designed for workers, dealership operators, payroll and HR teams, controllers, advocates, and counsel who need to understand the same system from different positions without changing the underlying evidence standard.</p>
      </div>
    </section>

    <section class="section section--mist">
      <div class="shell">
        <div class="section-heading"><div><p class="eyebrow">Release gates</p><h2>Every layer has a different burden.</h2></div><p>A link is not an authority analysis. A clean calculation is not a fact determination. A source-check date is not an unnamed confidence score.</p></div>
        <ol class="gate-list">{releaseGates.map((gate) => <li><span>{gate.number}</span><h3>{gate.object}</h3><p>{gate.gate}</p></li>)}</ol>
      </div>
    </section>

    <section class="section shell source-model">
      <div><p class="eyebrow">Source model</p><h2>State the proposition and its edge.</h2><a class="text-link" href="/authorities/">Open the authority register</a></div>
      <dl>
        <div><dt>Official source</dt><dd>Statutes, regulations, wage orders, judicial opinions, and official agency material are linked directly where available.</dd></div>
        <div><dt>Bounded proposition</dt><dd>Each source is connected to the precise rule or interpretive point for which it is used.</dd></div>
        <div><dt>Inferential limit</dt><dd>Each entry identifies a jurisdictional, factual, methodological, or remedial conclusion that the source cannot establish alone.</dd></div>
        <div><dt>Source-check record</dt><dd>The check date, scope, next check, and status note disclose what was reviewed without implying certification or perfect currency.</dd></div>
      </dl>
    </section>

    <section class="section method-boundary">
      <div class="shell boundary-grid">
        <div><p class="eyebrow">Boundary</p><h2>Precision includes refusing the wrong output.</h2></div>
        <div><p>The project does not decide a specific dispute, select a limitations period, establish class or group composition, provide representation, replace counsel, or map every local ordinance. Its instruments organize facts and perform bounded arithmetic in the browser; they do not transmit entries or transform incomplete facts into an adjudication.</p><a class="button" href="/disclaimer/">Read the complete limits</a></div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .page-hero { padding-block: var(--space-9) var(--space-7); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 2fr) minmax(18rem, 0.9fr); gap: var(--space-8); align-items: end; margin-bottom: var(--space-7); }
  .hero-grid h1,
  .hero-grid p { margin-bottom: 0; }
  .purpose-grid,
  .source-model,
  .boundary-grid { display: grid; grid-template-columns: minmax(16rem, 0.8fr) minmax(0, 1.6fr); gap: var(--space-8); }
  .purpose-grid { border-top: 4px solid var(--color-ink); }
  .purpose-copy p { max-width: 52rem; }
  .gate-list { margin: 0; padding: 0; border-top: 4px solid var(--color-ink); list-style: none; }
  .gate-list li { display: grid; grid-template-columns: 3rem minmax(12rem, 0.7fr) minmax(0, 1.5fr); gap: var(--space-5); border-bottom: var(--rule); padding-block: 1rem; }
  .gate-list span { color: var(--color-cobalt); font-family: var(--font-mono); font-size: 0.7rem; }
  .gate-list h3,
  .gate-list p { margin: 0; }
  .gate-list h3 { font-size: 1.2rem; }
  .gate-list p { font-size: 0.88rem; }
  .source-model { border-top: 4px solid var(--color-ink); }
  .source-model dl { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); margin: 0; }
  .source-model dl div { border-top: var(--rule); padding-top: 0.8rem; }
  .source-model dt { margin-bottom: 0.45rem; color: var(--color-cobalt-dark); font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; }
  .source-model dd { margin: 0; font-size: 0.88rem; }
  .method-boundary { background: var(--color-ink); color: white; }
  .boundary-grid h2 { color: white; }
  .boundary-grid > div:last-child p { color: #dbe5f1; }
  @media (max-width: 54rem) { .hero-grid, .purpose-grid, .source-model, .boundary-grid { grid-template-columns: 1fr; } }
  @media (max-width: 38rem) { .gate-list li { grid-template-columns: 2rem 1fr; } .gate-list p { grid-column: 2; } .source-model dl { grid-template-columns: 1fr; } }
</style>
