---
import { evidenceDomains, getEvidenceDomains, type EvidenceDomainId } from '../data/evidence';

interface Props {
  ids?: readonly EvidenceDomainId[];
  compact?: boolean;
  title?: string;
}

const { ids, compact = false, title = 'Evidence map' } = Astro.props;
const domains = ids ? getEvidenceDomains(ids) : evidenceDomains;
---

<section class:list={['evidence-map', { 'evidence-map--compact': compact }]} aria-label={title}>
  {!compact && <header><p class="eyebrow">Verify the inference</p><h2>{title}</h2></header>}
  <div class="evidence-list">
    {domains.map((domain, index) => (
      <article id={compact ? undefined : `evidence-${domain.id}`}>
        <div class="evidence-index">E{String(index + 1).padStart(2, '0')}</div>
        <div>
          <h3>{domain.label}</h3>
          {!compact && <ul>{domain.records.map((record) => <li>{record}</li>)}</ul>}
        </div>
        <dl>
          <div><dt>Can establish</dt><dd>{domain.canEstablish}</dd></div>
          <div><dt>Cannot establish alone</dt><dd>{domain.cannotEstablishAlone}</dd></div>
        </dl>
      </article>
    ))}
  </div>
</section>

<style>
  header { display: flex; justify-content: space-between; gap: 2rem; align-items: end; margin-bottom: var(--space-6); }
  header :where(h2, p) { margin-bottom: 0; }
  .evidence-list { border-top: 3px solid var(--color-ink); }
  article {
    display: grid;
    grid-template-columns: 3.2rem minmax(10rem, 1.25fr) minmax(0, 3fr);
    gap: var(--space-5);
    border-bottom: var(--rule);
    padding-block: 1.25rem;
  }
  .evidence-index { color: var(--color-cobalt); font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600; }
  h3 { margin-bottom: 0.7rem; font-size: 1.2rem; }
  ul { margin: 0; padding-left: 1.1rem; }
  li { color: var(--color-muted); font-size: 0.82rem; line-height: 1.45; }
  dl { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); margin: 0; }
  dt { margin-bottom: 0.35rem; color: var(--color-cobalt-dark); font-family: var(--font-mono); font-size: 0.64rem; font-weight: 600; text-transform: uppercase; }
  dd { margin: 0; color: var(--color-text); font-size: 0.86rem; line-height: 1.45; overflow-wrap: anywhere; }
  dl div:last-child { border-left: 2px solid var(--color-signal); padding-left: 0.8rem; }

  .evidence-map--compact .evidence-list { border-top-width: 2px; }
  .evidence-map--compact article { grid-template-columns: 2.3rem 1fr; gap: 0.5rem; padding-block: 0.8rem; }
  .evidence-map--compact h3 { font-size: 0.95rem; }
  .evidence-map--compact dl { grid-column: 2; grid-template-columns: 1fr; gap: 0.6rem; }
  .evidence-map--compact dl div:first-child { display: none; }
  .evidence-map--compact dd { font-size: 0.74rem; }

  @media (max-width: 48rem) {
    article { grid-template-columns: 2.5rem 1fr; }
    dl { grid-column: 2; }
  }
  @media (max-width: 34rem) { dl { grid-template-columns: 1fr; } dl div:last-child { margin-top: 0.35rem; } }
</style>
