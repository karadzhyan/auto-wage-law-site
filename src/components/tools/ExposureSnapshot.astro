    <div class="exposure-fields">
      <label><span>Employees in the group</span><input name="employeeCount" type="number" min="0" max="100000" step="1" value="12" required /></label>
      <label><span>Estimated weekly gap per employee</span><div class="unit-field"><input name="weeklyGapHours" type="number" min="0" max="168" step="0.01" value="2.5" required /><b>hr</b></div></label>
