---
import { roleCrosswalk } from '../data/analysis';

const columns = [
  { id: 'time', label: 'Time question' },
  { id: 'pay', label: 'Pay method' },
  { id: 'coverage', label: 'Coverage route' },
  { id: 'records', label: 'Proof packet' },
] as const;
---

<section class="role-crosswalk" aria-labelledby="role-crosswalk-title">
  <div class="crosswalk-intro">
    <div>
      <p class="eyebrow">Role × issue crosswalk</p>
      <h2 id="role-crosswalk-title">The same label does not produce the same analysis.</h2>
    </div>
    <p>Choose a role to isolate one row, or compare all five. Every cell names a question—not a conclusion.</p>
  </div>

  <div class="role-filter no-print" aria-label="Filter the crosswalk by role">
    <button type="button" data-role="all" aria-pressed="true" aria-controls="role-crosswalk-table">Compare all</button>
    {roleCrosswalk.map((row) => <button type="button" data-role={row.id} aria-pressed="false" aria-controls="role-crosswalk-table">{row.label}</button>)}
  </div>

  <p class="sr-only" data-role-status aria-live="polite">Showing all five dealership roles.</p>

  <div id="role-crosswalk-table" class="crosswalk-table" tabindex="0" role="region" aria-label="Scrollable role and issue comparison">
    <table>
      <thead>
        <tr>
          <th scope="col">Dealership role</th>
          {columns.map((column) => <th scope="col">{column.label}</th>)}
        </tr>
      </thead>
      <tbody>
        {roleCrosswalk.map((row) => (
          <tr data-row={row.id}>
            <th scope="row"><span>{row.label}</span><small>{row.id === 'finance' ? 'Finance & insurance' : row.id}</small></th>
            {columns.map((column) => {
              const cell = row.cells[column.id];
              return (
                <td data-emphasis={cell.emphasis}>
                  <a href={cell.href}>
                    <strong>{cell.label}</strong>
                    <span>{cell.detail}</span>
                    <small>{cell.emphasis.replace('-', ' ')}</small>
                  </a>
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.role-crosswalk').forEach((crosswalk) => {
    const buttons = [...crosswalk.querySelectorAll<HTMLButtonElement>('[data-role]')];
    const rows = [...crosswalk.querySelectorAll<HTMLTableRowElement>('[data-row]')];
    const status = crosswalk.querySelector<HTMLElement>('[data-role-status]');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const selected = button.dataset.role ?? 'all';
        buttons.forEach((candidate) => candidate.setAttribute('aria-pressed', String(candidate === button)));
        rows.forEach((row) => { row.hidden = selected !== 'all' && row.dataset.row !== selected; });
        if (status) status.textContent = selected === 'all' ? 'Showing all five dealership roles.' : `Showing ${button.textContent?.trim() ?? 'selected'} role.`;
      });
    });
  });
</script>

<style>
  .crosswalk-intro {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(16rem, 2fr);
    gap: var(--space-7);
    align-items: end;
    margin-bottom: var(--space-6);
  }
  .crosswalk-intro h2,
  .crosswalk-intro p { margin-bottom: 0; }
  .crosswalk-intro > p { color: var(--color-muted); }
  .role-filter { display: flex; flex-wrap: wrap; border-top: 3px solid var(--color-ink); }
  button {
    min-height: 2.75rem;
    border: 0;
    border-right: var(--rule);
    border-bottom: var(--rule);
    padding: 0.55rem 0.8rem;
    background: white;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    cursor: pointer;
  }
  button[aria-pressed='true'] { background: var(--color-ink); color: white; }
  .crosswalk-table { overflow-x: auto; outline-offset: -3px; }
  table { width: 100%; min-width: 72rem; border-collapse: collapse; table-layout: fixed; }
  th,
  td { border-right: var(--rule); border-bottom: var(--rule); text-align: left; vertical-align: top; }
  thead th {
    padding: 0.7rem;
    background: var(--color-paper-blue);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  thead th:first-child,
  tbody th { width: 9.5rem; border-left: var(--rule); }
  tbody th { padding: 1rem 0.7rem; background: var(--color-ink); color: white; }
  tbody th span { display: block; font-family: var(--font-display); font-size: 1rem; }
  tbody th small { color: #aebdd0; font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; }
  td a { display: grid; min-height: 9.3rem; gap: 0.55rem; padding: 1rem 0.8rem; text-decoration: none; }
  td a:hover { background: var(--color-paper-blue); }
  td strong { color: var(--color-ink); font-family: var(--font-display); line-height: 1.08; }
  td span { color: var(--color-text); font-size: 0.82rem; line-height: 1.4; }
  td small { align-self: end; color: var(--color-muted); font-family: var(--font-mono); font-size: 0.61rem; text-transform: uppercase; }
  td[data-emphasis='primary'] { box-shadow: inset 0 3px 0 var(--color-cobalt); }
  td[data-emphasis='exception-sensitive'] { box-shadow: inset 0 3px 0 var(--color-signal); }
  tr[hidden] { display: none; }

  @media (max-width: 48rem) {
    .crosswalk-intro { grid-template-columns: 1fr; gap: var(--space-4); }
    .crosswalk-table::after { content: 'Scroll to compare →'; display: block; padding-top: 0.65rem; color: var(--color-muted); font-family: var(--font-mono); font-size: 0.65rem; }
  }
</style>
