---
interface Source {
  label: string;
  url: string;
}
interface Props {
  sources: Source[];
}
const { sources } = Astro.props;
---

<aside class="authority-callout" aria-labelledby="authority-title">
  <p class="authority-kicker">Primary authority</p>
  <h2 id="authority-title">Read the rule, not just the summary.</h2>
  <ul>
    {sources.map((source) => (
      <li><a href={source.url} rel="external">{source.label}<span aria-hidden="true"> ↗</span></a></li>
    ))}
  </ul>
</aside>

<style>
  .authority-callout {
    margin-block: 3.5rem;
    border: 2px solid var(--color-cobalt);
    padding: clamp(1.25rem, 3vw, 2rem);
    background: var(--color-paper-blue);
  }

  .authority-kicker {
    margin-bottom: 0.75rem;
    color: var(--color-cobalt-dark);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    margin-bottom: 1.25rem;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  ul { margin: 0; padding-left: 1.2rem; }
  li + li { margin-top: 0.6rem; }
  a { color: var(--color-cobalt-dark); font-weight: 700; }
</style>
