---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnalysisSequence from '../../components/AnalysisSequence.astro';
import WageScenarioLab from '../../components/tools/WageScenarioLab.astro';
---

<BaseLayout title="Wage Scenario Lab" description="A browser-local sensitivity worksheet that decomposes entered straight-time, overtime-increment, and premium-hour assumptions without selecting the underlying legal or factual inputs.">
  <main id="main-content">
    <header class="tool-hero shell">
      <div><p class="eyebrow">Instrument 02 · Measure</p><h1>Separate the wage layers.</h1></div>
      <div class="hero-note"><p>Compare low, base, and high entered assumptions. The lab performs bounded arithmetic; it does not select hours, rates, people, periods, or remedies.</p><small>All entries stay on this device · nothing is retained</small></div>
    </header>
    <div class="shell"><AnalysisSequence current="measure" variant="compact" /></div>
    <section class="tool-stage"><div class="shell"><WageScenarioLab /></div></section>
    <section class="shell tool-foot"><p><strong>Use the output to test sensitivity, not to manufacture certainty.</strong> Replace every entered layer with a period-matched record and a legally appropriate calculation before drawing any external conclusion.</p><div><a class="text-link" href="/records/">Open the evidence map</a><a class="text-link" href="/disclaimer/">Read instrument limits</a></div></section>
  </main>
</BaseLayout>

<style>
  .tool-hero { display: grid; grid-template-columns: minmax(0, 2fr) minmax(18rem, 0.8fr); gap: var(--space-8); align-items: end; padding-block: clamp(3.5rem, 7vw, 6rem) var(--space-6); }
  .tool-hero h1 { max-width: 54rem; margin: 0; }
  .hero-note { border-top: 4px solid var(--color-ink); padding-top: 1rem; }
  .hero-note p { margin: 0; color: var(--color-text); }
  .hero-note small { display: block; margin-top: 0.8rem; color: var(--color-muted); font-family: var(--font-mono); font-size: 0.64rem; text-transform: uppercase; }
  .tool-stage { margin-top: var(--space-7); border-block: var(--rule); padding-block: clamp(1.25rem, 4vw, 3rem); background: var(--color-mist); }
  .tool-foot { display: flex; justify-content: space-between; gap: var(--space-7); padding-block: var(--space-7); }
  .tool-foot p { max-width: 48rem; margin: 0; }
  .tool-foot > div { display: grid; gap: 0.65rem; align-content: start; }
  @media (max-width: 52rem) { .tool-hero { grid-template-columns: 1fr; gap: var(--space-5); } .tool-foot { align-items: start; flex-direction: column; } }
</style>
