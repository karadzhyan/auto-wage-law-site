<div class="tool-frame" data-pay-plan-tool>
  <form class="worksheet" data-pay-plan-form novalidate>
    <div class="tool-panel-head">
      <p class="data-label">Worksheet · five steps</p>
      <span>Inputs stay in this browser</span>
    </div>

    <fieldset>
      <legend><span>01</span> Who does the work?</legend>
      <label for="role">Closest dealership role</label>
      <select id="role" name="role" required>
        <option value="technician">Flat-rate technician</option>
        <option value="sales">Salesperson</option>
        <option value="advisor">Service advisor</option>
        <option value="finance">F&I manager</option>
        <option value="support">Parts or support staff</option>
      </select>
    </fieldset>

    <fieldset>
      <legend><span>02</span> How is the work paid?</legend>
      <label for="payMethod">Primary pay method</label>
      <select id="payMethod" name="payMethod" required>
        <option value="piece-rate">Piece rate / flat rate</option>
        <option value="commission">Commission</option>
        <option value="mixed">Mixed rates or incentives</option>
        <option value="hourly">Hourly</option>
        <option value="salary">Salary</option>
      </select>
    </fieldset>

    <fieldset>
      <legend><span>03</span> Does the time reconcile?</legend>
      <div class="field-pair">
        <div><label for="onsiteHours">Time at dealership</label><div class="number-field"><input id="onsiteHours" name="onsiteHours" type="number" min="0" max="168" step="0.01" value="46" required /><span>hr</span></div></div>
        <div><label for="paidHours">Paid / accounted time</label><div class="number-field"><input id="paidHours" name="paidHours" type="number" min="0" max="168" step="0.01" value="38" required /><span>hr</span></div></div>
      </div>
    </fieldset>

    <fieldset>
      <legend><span>04</span> Is rest-period pay shown?</legend>
      <div class="choice-row">
        <label><input type="radio" name="restPayShown" value="yes" /> Yes</label>
        <label><input type="radio" name="restPayShown" value="no" checked /> No / not sure</label>
      </div>
    </fieldset>

    <fieldset>
      <legend><span>05</span> Is the written plan available?</legend>
      <div class="choice-row">
        <label><input type="radio" name="writtenPlanAvailable" value="yes" /> Yes</label>
        <label><input type="radio" name="writtenPlanAvailable" value="no" checked /> No / not sure</label>
      </div>
    </fieldset>

    <div class="form-error" data-form-error role="alert" hidden></div>
    <div class="tool-actions">
      <button class="button" type="submit">Run the check <span aria-hidden="true">→</span></button>
      <button class="reset-button" type="reset">Reset example</button>
    </div>
  </form>

  <section class="findings" data-pay-plan-results tabindex="-1" aria-live="polite">
    <div class="tool-panel-head">
      <p class="data-label">Findings sheet · educational orientation</p>
      <span data-finding-status>Illustrative result</span>
    </div>
    <div class="finding-summary">
      <span class="severity" data-severity>Potential gap</span>
      <div class="gap-readout"><strong data-gap-hours>8</strong><span>potential gap hours</span></div>
      <h2 data-finding-title>The inputs show a potential time gap.</h2>
      <p>This screen does not decide whether any law was violated. It identifies records and assumptions worth reviewing.</p>
    </div>
    <div class="finding-detail">
      <div>
        <h3>Why it surfaced</h3>
        <ul data-reasons></ul>
      </div>
      <div>
        <h3>Pull these records next</h3>
        <ol data-next-steps></ol>
      </div>
    </div>
    <aside class="scope-note">
      <strong>Scope boundary</strong>
      <p>California and federal orientation only. Local ordinances, complete exemption tests, penalties, and claim-specific facts require separate review.</p>
    </aside>
    <button class="print-button no-print" type="button" data-print-results>Print findings</button>
  </section>
</div>

<script>
  import { initializePayPlanCheck } from '../../scripts/pay-plan-check.ts';
  initializePayPlanCheck();
</script>

